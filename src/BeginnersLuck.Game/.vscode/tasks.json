{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/BeginnersLuck.sln", "-c", "Debug"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run",
      "command": "dotnet",
      "type": "process",
      "args": ["run", "--project", "${workspaceFolder}/src/BeginnersLuck.Game/BeginnersLuck.Game.csproj"],
      "problemMatcher": "$msCompile",
      "dependsOn": "build"
    }
  ]
}
